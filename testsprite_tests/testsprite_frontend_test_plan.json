  {
    "id": "TC016",
    "title": "Create startup with required fields only (name, description, categories)",
    "description": "Verifies an authenticated user can create a startup using only required fields and is redirected to a post-create page.",
    "category": "Create Startup",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Log in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/build\" or \"/startups\" or \"/landing\""
      },
      {
        "type": "action",
        "description": "Click on the \"Build\" or \"Create\" navigation link/button to open the create startup form"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/build\""
      },
      {
        "type": "action",
        "description": "Type \"Campus Pantry\" into the startup name field"
      },
      {
        "type": "action",
        "description": "Type \"A student-led pantry service that provides affordable meal kits and essentials on campus.\" into the description field"
      },
      {
        "type": "action",
        "description": "Select a category tag"
      },
      {
        "type": "action",
        "description": "Select a second category tag"
      },
      {
        "type": "action",
        "description": "Select a third category tag"
      },
      {
        "type": "action",
        "description": "Click the \"Create startup\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/startup/\" or \"/startups\""
      }
    ]
  },
